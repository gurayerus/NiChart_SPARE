{
  "description": {
    "spare_type": "CL",
    "model_tag": "SPARE_DIABETES",
    "model_version": "1.0",
    "run_tag": "SPARE_DIABETES_v1.0"
  },

  "input": {
    "in_dir": ".",
    "in_csv": "raw_data.csv",
    "key_col": "MRID",
    "target_col": "disease",
    "data_cols": ["Age", "Sex_M", "DL_MUSE_Volume_702", "H_DL_MUSE_Volume_*"]
  },

  "pre-processing": {
    "residualization": {
      "age_col": "Age",
      "sex_col": "Sex_M",
      "icv_col": "DL_MUSE_Volume_702"
    }
  },

  "model": {
    "svm_kernel": "linear",
    "hyperparameter_tuning": true,
    "train_whole": true,
    "cv_fold": 5,
    "class_balancing": true,
    "verbose": 1
  },

  "post-processing": {},

  "output": {
    "out_dir": "../output",
    "out_csv": "pred_train.csv",
    "out_cols": ["MRID", "SPARE_CL"],
    "out_model_dir": "model"
  }

}
